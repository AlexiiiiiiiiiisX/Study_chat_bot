# --- Postgres 
POSTGRES_USER=studybuddy
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=study_chat_bot
POSTGRES_PORT=5432

# --- JWT ---
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_ALEATORIO_DE_64_CARACTERES
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MIN=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:5173
COOKIE_SECURE=False
BACKEND_PORT=8000

# --- LLM / RAG ---

# https://aistudio.google.com/apikey
GEMINI_API_KEY=TU_API_KEY_DE_GOOGLE_AI_STUDIO
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_LITE=gemini-2.5-flash-lite

# --- Google OAuth (cuando se implemente) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
