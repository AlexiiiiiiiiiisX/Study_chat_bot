# --- Postgres 
POSTGRES_USER=studybuddy
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=study_chat_bot
POSTGRES_PORT=5432

# --- JWT ---
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_ALEATORIO_DE_64_CARACTERES
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MIN=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:3000
COOKIE_SECURE=False
BACKEND_PORT=8000

# --- LLM / RAG ---

# https://aistudio.google.com/apikey
GEMINI_API_KEY=TU_API_KEY_DE_GOOGLE_AI_STUDIO
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MODEL_LITE=gemini-3.1-flash-lite

# --- Google OAuth ---
# Crea las credenciales "Web application" en Google Cloud Console.
# Añade esta URL como URI de redirección autorizada.

GOOGLE_CLIENT_ID=valor_de_client_id_del_bloque_"web"_en_el_JSON
GOOGLE_CLIENT_SECRET=tu_valor_actual
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback